// nf-bam2identity - generic SLURM profile
//
// This file keeps HPC execution settings separate from analysis parameters.
// Edit the values below to match the target cluster.
//
// Usage:
// nextflow run main.nf -profile slurm -params-file params.yaml -resume

params.slurm_queue = 'standard'

params.slurm_default_cpus = 1
params.slurm_default_memory = '4 GB'
params.slurm_default_time = '02:00:00'

params.slurm_angsd_cpus = 4
params.slurm_angsd_memory = '16 GB'
params.slurm_angsd_time = '06:00:00'

params.slurm_ngsrelate_cpus = 4
params.slurm_ngsrelate_memory = '8 GB'
params.slurm_ngsrelate_time = '04:00:00'

// Example module names. Replace these with the actual module names available
// on the target cluster.
params.slurm_angsd_module = 'angsd/0.940'
params.slurm_ngsrelate_module = 'ngsrelate/2.0'

// Optional cluster-specific settings. Leave null or empty when not required.
params.slurm_account = null
params.slurm_qos = null
params.slurm_constraint = null
params.slurm_mail_user = null
params.slurm_mail_type = 'END,FAIL'
params.slurm_extra_options = []

profiles {
    slurm {
        docker.enabled = false

        process {
            executor = 'slurm'
            queue = params.slurm_queue

            cpus = params.slurm_default_cpus
            memory = params.slurm_default_memory
            time = params.slurm_default_time

            clusterOptions = [
                params.slurm_account ? "--account=${params.slurm_account}" : null,
                params.slurm_qos ? "--qos=${params.slurm_qos}" : null,
                params.slurm_constraint ? "--constraint=${params.slurm_constraint}" : null,
                params.slurm_mail_user ? "--mail-user=${params.slurm_mail_user}" : null,
                params.slurm_mail_user && params.slurm_mail_type ? "--mail-type=${params.slurm_mail_type}" : null
            ].findAll { it } + params.slurm_extra_options

            withName: 'bam2identity_angsd' {
                cpus = params.slurm_angsd_cpus
                memory = params.slurm_angsd_memory
                time = params.slurm_angsd_time
                container = null
                module = params.slurm_angsd_module
            }

            withName: 'bam2identity_ngsRelate' {
                cpus = params.slurm_ngsrelate_cpus
                memory = params.slurm_ngsrelate_memory
                time = params.slurm_ngsrelate_time
                container = null
                module = params.slurm_ngsrelate_module
            }
        }
    }
}
